{
  "name": "srsuya-whatsapp-bot",
  "version": "0.1.0",
  "description": "WhatsApp Multi-Device bot built with Baileys MD — structured, modular and ready for Termux.",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "update": "bash scripts/update.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@adiwajshing/baileys": "^4.8.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^8.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pino": "^8.20.0",
    "pg": "^8.11.0",
    "ws": "^8.13.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.6",
    "eslint": "^8.46.0",
    "prettier": "^3.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.6"
  }
}
