# Bot Configuration
BOT_NAME=Nuvem Bot
BOT_VERSION=1.0.0
NODE_ENV=development

# Baileys Configuration
SESSION_FOLDER=./storage/sessions
AUTH_FOLDER=./storage/auth
TEMP_FOLDER=./temp

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=./storage/database.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=nuvem_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# API Server
API_PORT=3000
API_HOST=0.0.0.0
ENABLE_API=true
ENABLE_WEBSOCKET=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# Features
ENABLE_ANTIBOT=true
ENABLE_ANTISPAM=true
ENABLE_ANTIFLOOD=true
ENABLE_ANTILINK=true
ENABLE_ANTITRAVA=true
ENABLE_WELCOME=true

# Backup
ENABLE_BACKUP=true
BACKUP_INTERVAL=86400000
BACKUP_FOLDER=./storage/backups

# Admin Settings
ADMIN_ONLY_COMMANDS=false
PREFIX=!

# Owner IDs (separado por vírgula)
OWNER_IDS=5521999999999@s.whatsapp.net

# Security
ENCRYPTION_KEY=nuvem-bot-2024-secure-key-change-in-production
